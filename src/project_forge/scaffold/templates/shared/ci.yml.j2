name: CI

on:
  push:
    branches: [main]
  pull_request:
    branches: [main]

jobs:
{% if language == "python" %}
  lint:
    runs-on: [self-hosted, Linux]
    steps:
      - uses: actions/checkout@v4
      - name: Lint
        run: python3 -m ruff check src/ tests/

  test:
    runs-on: [self-hosted, Linux]
    needs: lint
    steps:
      - uses: actions/checkout@v4
      - name: Install
        run: pip install --user --break-system-packages -e ".[test]"
      - name: Test
        run: python3 -m pytest tests/ -v
{% elif language == "node" %}
  lint:
    runs-on: [self-hosted, Linux]
    steps:
      - uses: actions/checkout@v4
      - name: Install
        run: npm ci
      - name: Lint
        run: npm run lint

  test:
    runs-on: [self-hosted, Linux]
    needs: lint
    steps:
      - uses: actions/checkout@v4
      - name: Install
        run: npm ci
      - name: Test
        run: npm test
{% else %}
  test:
    runs-on: [self-hosted, Linux]
    steps:
      - uses: actions/checkout@v4
      - name: Test
        run: echo "Add tests for {{ language }}"
{% endif %}
