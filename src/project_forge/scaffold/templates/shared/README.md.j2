### Installation

```bash
git clone {{ repo_url }}
cd {{ repo_name }}
{% if language == "python" %}
# Using uv (recommended)
uv venv && source .venv/bin/activate
uv pip install -e ".[dev,test]"

# Or using pip
python -m venv .venv && source .venv/bin/activate
pip install -e ".[dev,test]"
{% elif language == "node" %}
npm install
{% elif language == "rust" %}
cargo build
{% elif language == "go" %}
go mod download
go build ./...
{% endif %}```

### Running

```bash
{% if language == "python" %}{% if framework == "fastapi" %}uvicorn {{ repo_name | replace("-", "_") }}.app:app --reload
